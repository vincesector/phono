# Resend (optional) — for footer newsletter
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Vercel Blob (required for share links)
# Create a store at vercel.com → Storage → Blob
# Get the token from the store's .env.local tab
BLOB_READ_WRITE_TOKEN=

# The public base URL for your Blob store
# Format: https://XXXXXXXXX.public.blob.vercel-storage.com
# Visible on the Vercel Blob store page
NEXT_PUBLIC_BLOB_BASE_URL=
